    end

    subgraph "4. Decision Layer (Tầng Quyết định & An toàn)"
        D1[Risk threshold analyzer]
        D2[Recommendation engine]
        D3[Safety hard-coded rules]
    end

    subgraph "5. Application Layer (Giao diện & Chấp hành)"
        E1[Smart Home Mobile App]
